# IstiqamahBN Backend Configuration

# Timezone
TZ=Asia/Brunei

# Database
DATABASE_PATH=/app/data/prayer_times.db

# MORA Website URL
MORA_URL=https://www.mora.gov.bn/SitePages/WaktuSembahyang.aspx

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Update Schedule (cron format)
# Default: January 1st at 00:00 Brunei time
UPDATE_SCHEDULE=0 0 1 1 *

# Web Push (VAPID) — generate with: python generate_vapid_keys.py
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CONTACT=mailto:admin@istiqamahbn.com

# Admin API Key — used for /admin panel and protected endpoints
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=
